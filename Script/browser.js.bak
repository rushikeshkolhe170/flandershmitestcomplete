//Verifying the change in dashboard for auto drill parameter and cross check in the HMI

const {config, launchHMI, closeHMI, commissioningPass, openDiagnosticDashboard, closeDiagnosticDashboard} = require('GlobalVariables');
const {browserToggleSwitchStatus, scrollIntoViewBrowser} = require('CommonFunc');
const {Browser_Variables, Commissioning_Variables, UI_Variables, AutoDrillPara_Variables} = require('BrowserPage');

function Test1()
{
  //Checking if the HMI is open and if yes then it will close first and then open
  if(Aliases.Flanders_Ardvarc_Hmi_Client.HwndSource_MainWindow.MainWindow.Exists){
    closeHMI();
  }
  aqUtils.Delay(3000);
  //open diagnostic dashboard browser.
  openDiagnosticDashboard();
  //Clicks the 'linkCommissioning' link.
  Browser_Variables.CommissioningOption().Click();
  //Waits until the browser loads the page and is ready to accept user input.
  Aliases.browser.pageDiagnosticDashboard2.Wait();
  //Clicks the 'panelUi' control.
  Commissioning_Variables.UI_Opt().Click();
  //Clicks the 'buttonAutoDrillParameters' button.
  UI_Variables.AutoDrillParameter_Btn().Click();
  //Scroll until the Drill Hole Depth text gets in the view
  scrollIntoViewBrowser(Aliases.msedge.pageDiagnosticDashboard3.FindElement("//h1[.='Drill Hole Depth']"));
  //Cheking the show option for drill hole depth if it's off turning it on
  if(browserToggleSwitchStatus(AutoDrillPara_Variables.DrillHoleDepthShow_Btn()) == 0 ){
    AutoDrillPara_Variables.DrillHoleDepthShow_Btn().Click();
  }else{
    Log.Message("Drill Hole Depth toggle button is already ON");
  }
  //Click on Save option
  Browser_Variables.Save_Btn().Click();
  //Click on Save for confirmation pop up
  Browser_Variables.ConfirmationSave_Btn().Click();
  
}

function Test2()
{
  //Opens the specified URL in a running instance of the specified browser.
  Browsers.Item(btEdge).Navigate("http://wsl.flanders.local/login/");
  Aliases.msedge.wndChrome_WidgetWin_1.Maximize();
  //Clicks the 'panelLogin' control.
  Aliases.msedge.pageDiagnosticDashboard4.panelLogin.Click();
  //Clicks the 'textbox' control.
  Aliases.msedge.pageDiagnosticDashboard4.textbox.Click();
  //Sets the text 'admin' in the 'textbox' text editor.
  Aliases.msedge.pageDiagnosticDashboard4.textbox.SetText("admin");
  //Enters '[Tab]' in the 'textbox' object.
  Aliases.msedge.pageDiagnosticDashboard4.textbox.Keys("[Tab]");
  //Sets the text Project.Variables.DiagnoDashboardPass in the 'passwordbox' text editor.
  Aliases.msedge.pageDiagnosticDashboard4.passwordbox.SetText(Project.Variables.DiagnoDashboardPass);
  //Clicks the 'buttonLogin' button.
  Aliases.msedge.pageDiagnosticDashboard4.buttonLogin.ClickButton();
  //Waits until the browser loads the page and is ready to accept user input.
  Aliases.msedge.pageDiagnosticDashboard2.Wait();
  //Clicks the 'textnodeCommissioning' control.
  Aliases.msedge.pageDiagnosticDashboard2.navAlarmsOverview.textnodeCommissioning.Click();
  //Waits until the browser loads the page and is ready to accept user input.
  Aliases.msedge.pageDiagnosticDashboard3.Wait();
  //Clicks the 'panelUi' control.
  Aliases.msedge.pageDiagnosticDashboard3.panelUi.Click();
  //Clicks the 'buttonAutoDrillParameters' button.
  Aliases.msedge.pageDiagnosticDashboard3.buttonAutoDrillParameters.ClickButton();
  //Clicks the 'numberinput' control.
  Aliases.msedge.pageDiagnosticDashboard3.numberinput.Click();
  //Clicks the 'panel' control.
  Aliases.msedge.pageDiagnosticDashboard3.panel.Click();
  //Clicks the 'buttonSwitch2' button.
  Aliases.msedge.pageDiagnosticDashboard3.buttonSwitch2.ClickButton();
  //Clicks the 'buttonSave1' button.
  Aliases.msedge.pageDiagnosticDashboard3.buttonSave1.ClickButton();
  //Clicks the 'buttonSave' button.
  Aliases.msedge.pageDiagnosticDashboard3.buttonSave.ClickButton();
}