
//Importing Boundary
//Removving Boundary

const {config, launchHMI, closeHMI} = require('GlobalVariables');
const {logIn, wpfControlText, verifyWpfControlTextWithExistCheck, checkVisibilityAndClick, verifyVisibilityWithExistCheck} = require('CommonFunc');
const {mainOptionVariables} = require('MainOptionsVariable');
const {mainScreenVariables} = require('MainScreenPage');
const {setupVariables} = require('SetupPage');

function BoundaryImport()
{
  //Runs the "Flanders_Ardvarc_Hmi_Client" tested application.
  logIn();
  //Clicks the 'SetupButton' button.
  mainOptionVariables.Setup_Btn.ClickButton();
  //Clicks the 'ButtonImportPattern' button.
  setupVariables.ImportPattern_Btn.ClickButton();
  //Clicks the 'ButtonSelectFileToImport' button.
  setupVariables.SelectFileToImport_Btn.ClickButton();
  //Creating the generic path to the Boundry.csv file (Make sure file is available in the HMI project file location)
  var projectDir = Project.Path;
  var relativeFilePath = "\Boundary.csv";
  var fullFilePath = projectDir + relativeFilePath;
  Log.Message("Full file path: " + fullFilePath);
  //Entering the path in file explorer dialogue directly and selecting the file
  Aliases.Flanders_Ardvarc_Hmi_Client.dlg.OpenFile(fullFilePath);
  //Capturing the path showing below the import button
  var location = wpfControlText(setupVariables.ImportBoxGroup.Child(0).Child(1).Child(0).Child(8).Child(5));
  //verifying the file path and location showing below the import button
  if(fullFilePath == location){
    Log.Message("File path and location shows below the import button is same");
  } else {
    Log.Warning("File path and Location shown below import button is differnet");
  }
  //Clicks the 'ButtonImport' button.
  setupVariables.Import_Btn.ClickButton();
  //Checks whether the 'WPFControlText' property of the Dialogue message object equals '4 boundary records were imported.'.
  verifyWpfControlTextWithExistCheck(setupVariables.DialogueMsg_Text, "4 boundary records were imported.");
  //Clicks the 'OkButtonText' object.
  setupVariables.DialogueOk_Btn.ClickButton();
  //Clicks the 'MoveBack' object.
  setupVariables.Back_Btn.Click();
  //Closes the 'HwndSource_MainWindow' window.
  closeHMI();
}

function BoundaryRemove()
{
  //Runs the "Flanders_Ardvarc_Hmi_Client" tested application.
  logIn();
  //Clicks the 'SetupButton' button.
  mainOptionVariables.Setup_Btn.ClickButton();
  //Clicks the 'ButtonImportPattern' button.
  setupVariables.ImportPattern_Btn.ClickButton();
  //Clicks the 'ButtonRemovePatterns' button.
  setupVariables.RemovePattern_Btn.ClickButton();
  //Selects the 'Boundary' tab of the 'TabControl' tab control.
  setupVariables.TabControl.ClickTab("Boundary");
  //Going through list in Boundary section and selecting the option with Boundary as text.
  var ele = setupVariables.ListBoxItems;
  var count = ele.ChildCount;
  for(var i = 1; i<count; i++)
  {
    var count1 = ele.Child(i).Child(0).ChildCount;
    for(var j = 0; j<count1; j++)
    {
      if(wpfControlText(ele.Child(i).Child(0).Child(j)) == "Boundary")
      {
        ele.Child(i).Child(0).Child(j).Click();
        break;
      }
      else
      {
        Log.Error("No Boundary file found with name 'Boundary'");
      }
    }
  }
  //Checks whether the 'IsVisible' property of the preview object equals True.
  verifyVisibilityWithExistCheck(setupVariables.PreviewOfBoundary);
  //Clicks the 'ButtonRemoveSelectedPatterns' button.
  setupVariables.RemoveSelectedPattern_Btn.ClickButton();
  //Checks whether the 'IsVisible' property of the Confirmation Message text object equals True.
  verifyVisibilityWithExistCheck(setupVariables.ConfirmationDialogueBox_Text);
  //Clicks the 'YesButton' button.
  setupVariables.ConfirmationDialogueYES_Btn.ClickButton();
  //Checks whether the 'IsVisible' property of the Dialogue box text object equals True.
  verifyVisibilityWithExistCheck(setupVariables.DialogueMsg_Text);
  //Clicks the 'OkButtonText' object.
  setupVariables.DialogueOk_Btn.ClickButton();
  //Clicks the 'MoveBack' object.
  setupVariables.Back_Btn.Click();
  //Closes the 'HwndSource_MainWindow' window.
  closeHMI();
}

