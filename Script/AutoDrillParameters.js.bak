  verifyWpfControlTextWithExistCheck(setupVariables.CalcTitle_Label, "DRILL HOLE DEPTH:");
  //Clicks the -1 input.
  setupVariables.CalculatorWindow.ButtonAddMinus.ClickButton();
  setupVariables.CalculatorWindow.Button1.ClickButton();
  //Clicks the 'ButtonAccept' button.
  setupVariables.CalcAccept_Btn.ClickButton();
  //Checks whether the 'WPFControlText' property of the dialogue box object equals 'You must enter a value between 0 and 100 to continue.'.
  verifyWpfControlTextWithExistCheck(setupVariables.DialogueMsg_Text, "You must enter a value between 0 and 100 to continue.");
  //Clicks the 'OkButtonText' object.
  setupVariables.DialogueOk_Btn.ClickButton();
  //Clicks the 'ButtonClear' button.
  setupVariables.CalcClear_Btn.ClickButton();
  //Clicks the '101' button.
  setupVariables.CalculatorWindow.Button1.ClickButton();
