  var AirPressureDrillingValue = setupVariables.Parameter_Value.Border22.Child(0).Child(1);
  var BitAirPressureValue = setupVariables.Parameter_Value.Border4.Child(0).Child(1);
  var BitSpecifiedDownForceLimitValue = setupVariables.Parameter_Value.Border5.Child(0).Child(1);
  var DrillingFeedDownSpeedReferenceValue = setupVariables.Parameter_Value.Border3.Child(0).Child(1);
  var TargetDepthSubDrillValue = setupVariables.Parameter_Value.Border.Child(0).Child(1);
  var DHD = wpfControlText(DrillHoleDepthValue);
  var APD = wpfControlText(AirPressureDrillingValue);
  var BAP = wpfControlText(BitAirPressureValue);
  var BSDFL = wpfControlText(BitSpecifiedDownForceLimitValue);
  var DFDSR = wpfControlText(DrillingFeedDownSpeedReferenceValue);
  var TDSD = wpfControlText(TargetDepthSubDrillValue);
  //Checks whether the 'WPFControlText' property of the first label object equals 'DRILL HOLE DEPTH:'.
  verifyWpfControlTextWithExistCheck(setupVariables.DrillHoleDepth_Label, "DRILL HOLE DEPTH:");
  //Clicks the first calculator button.
  setupVariables.DrillHoleDepthCalc_Btn.ClickButton();
