  aqObject.CheckProperty(Aliases.Flanders_Ardvarc_Hmi_Client.HwndSource_SeriousWindow.SeriousWindow.TabControl.SettingsListView.ListViewItem2.TextblockMaintenancekeypadrightbottomshow, "WPFControlText", cmpEqual, "MaintenanceKeypadRightBottomShow");
